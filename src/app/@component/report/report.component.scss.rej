+
+/* Tab bar */
+.tab-bar {
+  display: flex;
+  gap: 8px;
+  margin-bottom: 20px;
+  border-bottom: 2px solid $border-radius-color;
+  padding-bottom: 0;
+}
+
+.tab {
+  padding: 10px 24px;
+  border: none;
+  border-bottom: 2px solid transparent;
+  margin-bottom: -2px; // 蓋掉 tab-bar 的底線
+  background: none;
+  font-family: inherit;
+  font-size: $font-size-base;
+  font-weight: 500;
+  color: $text-gray;
+  cursor: pointer;
+  transition: color 0.2s, border-color 0.2s;
+  border-radius: 0;
+
+  &:hover {
+    color: $text-black;
+  }
+
+  &.active {
+    color: $text-black;
+    font-weight: 700;
+    border-bottom-color: $primary-yellow;
+  }
+}
+
